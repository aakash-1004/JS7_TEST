{
  "TYPE" : "Workflow",
  "version" : "1.8.3",
  "timeZone" : "Europe/Berlin",
  "orderPreparation" : {
    "parameters" : {
      "booking_code" : {
        "type" : "String"
      },
      "flight_destination" : {
        "type" : "String"
      },
      "desired_seat_no" : {
        "type" : "Number",
        "default" : "0"
      },
      "desired_newspaper" : {
        "type" : "Boolean",
        "default" : "false"
      }
    },
    "allowUndeclared" : false
  },
  "jobResourceNames" : [ "Default" ],
  "instructions" : [ {
    "TYPE" : "Execute.Named",
    "jobName" : "job1",
    "label" : "job1"
  } ],
  "jobs" : {
    "job1" : {
      "agentName" : "primaryAgent",
      "withSubagentClusterIdExpr" : false,
      "executable" : {
        "TYPE" : "ShellScriptExecutable",
        "script" : "echo \"using workflow: $JS7_WORKFLOW_NAME\"\necho \"running job: $JS7_JOB_NAME\"\n\necho \"booking code: $BOOKING_CODE\"\necho \"flight destination: $FLIGHT_DESTINATION\"\n\necho \"desired seat no: $DESIRED_SEAT_NO\"\necho \"desired newspaper: $DESIRED_NEWSPAPER\"\n\nsleep 5",
        "env" : {
          "BOOKING_CODE" : "$booking_code",
          "FLIGHT_DESTINATION" : "$flight_destination",
          "DESIRED_SEAT_NO" : "$desired_seat_no",
          "DESIRED_NEWSPAPER" : "\"$desired_newspaper \""
        },
        "v1Compatible" : false
      },
      "skipIfNoAdmissionForOrderDay" : false,
      "killAtEndOfAdmissionPeriod" : false,
      "parallelism" : 1,
      "graceTimeout" : 15,
      "failOnErrWritten" : false,
      "warnOnErrWritten" : false,
      "isNotRestartable" : false
    }
  }
}