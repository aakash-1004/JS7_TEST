    "job1" : {
      "agentName" : "primaryAgent",
      "withSubagentClusterIdExpr" : false,
      "executable" : {
        "TYPE" : "ShellScriptExecutable",
        "script" : "echo \"running job: $JS7_JOB_NAME\"\n\necho \"reading booking code from order variable: BOOKING_CODE = $BOOKING_CODE\"\necho \"reading flight destination from order variable: FLIGHT_DESTINATION = $FLIGHT_DESTINATION\"\n\nsleep 5",
        "env" : {
          "BOOKING_CODE" : "$booking_code",
          "FLIGHT_DESTINATION" : "$flight_destination"
        },
        "v1Compatible" : false
      },
      "skipIfNoAdmissionForOrderDay" : false,
      "killAtEndOfAdmissionPeriod" : false,
      "parallelism" : 1,
      "graceTimeout" : 15,
      "failOnErrWritten" : false,
      "warnOnErrWritten" : false,
      "isNotRestartable" : false
    },
    "job2" : {
      "agentName" : "primaryAgent",
