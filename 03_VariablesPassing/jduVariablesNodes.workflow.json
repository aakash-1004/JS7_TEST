{
  "TYPE" : "Workflow",
  "version" : "1.8.3",
  "timeZone" : "Etc/UTC",
  "title" : "Using variables from node arguments",
  "documentationName" : "PKB-JS7-OnlineDemo-Workflow-jdVariablesNodes",
  "orderPreparation" : {
    "parameters" : {
      "booking_code" : {
        "type" : "String",
        "default" : "'TX78'"
      },
      "flight_destination" : {
        "type" : "String",
        "default" : "'Japan'"
      }
    },
    "allowUndeclared" : false
  },
  "instructions" : [ {
    "TYPE" : "Execute.Named",
    "jobName" : "job1",
    "label" : "job1"
  }, {
    "TYPE" : "Execute.Named",
    "jobName" : "job2",
    "label" : "job2"
  }, {
    "TYPE" : "Execute.Named",
    "jobName" : "job3",
    "label" : "job3"
  }, {
    "TYPE" : "Execute.Named",
    "jobName" : "job4",
    "defaultArguments" : {
      "node_booking_code" : "'TX78'",
      "node_flight_destination" : "'Berlin'"
    },
    "label" : "job4a"
  }, {
    "TYPE" : "Execute.Named",
    "jobName" : "job4",
    "defaultArguments" : {
      "node_booking_code" : "'CZDZ'",
      "node_flight_destination" : "'Prague'"
    },
    "label" : "job4b"
