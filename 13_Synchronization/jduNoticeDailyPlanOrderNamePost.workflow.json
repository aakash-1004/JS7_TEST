{
  "TYPE" : "Workflow",
  "version" : "1.8.3",
  "timeZone" : "Etc/UTC",
  "title" : "Post notices to jdNoticeDailyPlan* notice boards",
  "jobResourceNames" : [ "Default" ],
  "instructions" : [ {
    "TYPE" : "Execute.Named",
    "jobName" : "job1",
    "label" : "job1"
  }, {
    "TYPE" : "PostNotices",
    "noticeBoardNames" : [ "jduNoticeDailyPlan" ]
  }, {
    "TYPE" : "Execute.Named",
    "jobName" : "job2",
    "label" : "job2"
  }, {
    "TYPE" : "PostNotices",
    "noticeBoardNames" : [ "jduNoticeDailyPlanOrderName" ]
