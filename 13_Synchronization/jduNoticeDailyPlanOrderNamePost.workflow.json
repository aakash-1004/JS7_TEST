    "TYPE" : "Execute.Named",
    "jobName" : "job3",
    "label" : "job3"
  } ],
  "jobs" : {
    "job1" : {
      "agentName" : "primaryAgent",
      "withSubagentClusterIdExpr" : false,
      "executable" : {
