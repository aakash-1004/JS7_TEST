      "executable" : {
        "TYPE" : "ShellScriptExecutable",
        "script" : "echo \"using workflow: $JS7_WORKFLOW_NAME\"\necho \"running job: $JS7_JOB_NAME\"\n\nsleep 5\n\nexit $RETURN_CODE_JOB3",
        "env" : {
          "RETURN_CODE_JOB3" : "$return_code_job3"
